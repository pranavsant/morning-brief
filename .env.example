# ─────────────────────────────────────────────────────────────
#  Morning Brief — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to source control.
# ─────────────────────────────────────────────────────────────

# Anthropic Claude API key
# Get yours at: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# NewsAPI.org key
# Get yours at: https://newsapi.org/register
VITE_NEWS_API_KEY=your_newsapi_key_here

# Optional: override the Claude model (default: claude-3-5-haiku-20241022)
VITE_CLAUDE_MODEL=claude-3-5-haiku-20241022

# Optional: max articles fetched per category (default: 5)
VITE_MAX_ARTICLES_PER_CATEGORY=5
