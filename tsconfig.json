{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Paths */
    "baseUrl": ".",
    "paths": {
      // ── Clean-Architecture layer aliases ────────────────────────────────
      "@domain/*":         ["src/domain/*"],
      "@application/*":    ["src/application/*"],
      "@infrastructure/*": ["src/infrastructure/*"],
      "@interfaces/*":     ["src/interfaces/*"],

      // ── Shorthand aliases inside the interfaces (UI) layer ──────────────
      // "@/" maps into src/interfaces/ for concise in-layer imports.
      // More-specific entries are listed first; TypeScript matches them
      // before falling through to the wildcard "@/*".
      "@/components/*":  ["src/interfaces/components/*"],
      "@/pages/*":       ["src/interfaces/pages/*"],
      "@/hooks/*":       ["src/interfaces/hooks/*"],
      "@/controllers/*": ["src/interfaces/controllers/*"],
      "@/lib/*":         ["src/interfaces/lib/*"],
      "@/di/*":          ["src/interfaces/di/*"],
      "@/*":             ["src/interfaces/*"]
    },

    /* Strict */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "exactOptionalPropertyTypes": true
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
